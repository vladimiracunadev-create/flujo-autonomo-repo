{
  "id": "screen_watchdog_rules",
  "name": "Watchdog visual por reglas",
  "family": "pantalla",
  "description": "Captura la pantalla, la analiza y toma una decisión declarativa basada en reglas locales.",
  "steps": [
    {
      "id": "capture_screen",
      "action": "screen.capture_screenshot",
      "params": {"output_path": "output/screenshots/watchdog_{now}.png"},
      "save_as": "capture",
      "retries": 1
    },
    {
      "id": "analyze_capture",
      "action": "vision.analyze_image",
      "params": {"image_path": "{{ capture.image_path }}", "analyzer": "mock"},
      "save_as": "analysis"
    },
    {
      "id": "evaluate_visual_rules",
      "action": "rules.evaluate",
      "params": {
        "input_data": {"analysis": "{{ analysis }}"},
        "default_status": "estable",
        "rules": [
          {"id": "pantalla_oscura", "path": "analysis.visual_state", "operator": "eq", "value": "oscuro", "status": "alerta", "message": "La pantalla salió muy oscura; podría haber bloqueo o ventana cerrada."},
          {"id": "pantalla_clara", "path": "analysis.visual_state", "operator": "eq", "value": "claro", "status": "ok", "message": "Estado visual claro y legible."}
        ]
      },
      "save_as": "decision"
    },
    {
      "id": "write_report",
      "action": "filesystem.write_json",
      "params": {
        "path": "output/reports/screen_watchdog_{now}.json",
        "data": {"capture": "{{ capture }}", "analysis": "{{ analysis }}", "decision": "{{ decision }}"}
      },
      "save_as": "report"
    }
  ]
}
