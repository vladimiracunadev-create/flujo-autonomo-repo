{
  "id": "branching_document_router",
  "name": "Router documental con branching",
  "family": "documentos",
  "description": "Demostración canónica de transitions con condiciones: escanea data/dropbox/inbox, decide ruta. Si total_files > 0 → 4 pasos de procesamiento (clasifica, resume, reporta archivos). Si vacío → 1 paso de reporte vacío. La rama no tomada queda como NOT_TAKEN en la UI. ~0.3s. Plantilla para pipelines documentales con bifurcación.",
  "steps": [
    {
      "id": "scan_input",
      "action": "filesystem.list_directory",
      "params": {"path": "{{ source_path }}", "recursive": false},
      "save_as": "inventory"
    },
    {
      "id": "decide_route",
      "action": "rules.evaluate",
      "params": {
        "input_data": {"inventory": "{{ inventory }}"},
        "default_status": "sin_archivos",
        "rules": [
          {"id": "hay_archivos", "path": "inventory.total_files", "operator": "gt", "value": 0, "status": "hay_archivos", "message": "Hay archivos para procesar."}
        ]
      },
      "save_as": "decision",
      "transitions": [
        {"on": "success", "when": {"path": "decision.status", "operator": "eq", "value": "hay_archivos"}, "next": "classify_input"},
        {"on": "success", "next": "write_empty_report"}
      ]
    },
    {
      "id": "classify_input",
      "action": "filesystem.classify_file_inventory",
      "params": {"files": "{{ inventory.files }}"},
      "save_as": "stats"
    },
    {
      "id": "summarize_input",
      "action": "filesystem.summarize_text_folder",
      "params": {"path": "{{ source_path }}", "max_files": 10, "max_chars_per_file": 500},
      "save_as": "summary"
    },
    {
      "id": "write_processed_report",
      "action": "filesystem.write_json",
      "params": {
        "path": "output/reports/branching_processed_{now}.json",
        "data": {"inventory": "{{ inventory }}", "decision": "{{ decision }}", "stats": "{{ stats }}", "summary": "{{ summary }}"}
      },
      "save_as": "report",
      "transitions": [{"on": "success", "end": true}]
    },
    {
      "id": "write_empty_report",
      "action": "filesystem.write_json",
      "params": {
        "path": "output/reports/branching_empty_{now}.json",
        "data": {"inventory": "{{ inventory }}", "decision": "{{ decision }}", "message": "No había documentos que procesar."}
      },
      "save_as": "report",
      "transitions": [{"on": "success", "end": true}]
    }
  ]
}
