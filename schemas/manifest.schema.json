{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vladimiracunadev-create/flujo-autonomo-repo/schemas/manifest.schema.json",
  "title": "Flujo Autónomo manifest",
  "description": "Contrato declarativo de un flow. Cada caso vive en flows/<folder>/manifest.json.",
  "type": "object",
  "required": ["id", "name", "steps"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9_]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "family": { "type": "string", "default": "general" },
    "start_step": { "type": "string" },
    "max_steps_per_run": { "type": "integer", "minimum": 1, "maximum": 10000, "default": 200 },
    "allowed_actions": {
      "description": "Lista blanca de acciones permitidas. Si está presente, sólo estas pueden ejecutarse en el flow.",
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "required_secrets": {
      "description": "Variables de entorno que el flow espera ver definidas antes de correr.",
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "action"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "save_as": { "type": "string" },
        "retries": { "type": "integer", "minimum": 0, "maximum": 100, "default": 0 },
        "when": { "$ref": "#/$defs/condition" },
        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/transition" }
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "on": { "type": "string", "enum": ["success", "failure", "any"], "default": "success" },
        "next": { "type": "string" },
        "end": { "type": "boolean", "default": false },
        "when": { "$ref": "#/$defs/condition" }
      }
    },
    "condition": {
      "oneOf": [
        {
          "type": "object",
          "required": ["all"],
          "properties": { "all": { "type": "array", "items": { "$ref": "#/$defs/condition" } } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["any"],
          "properties": { "any": { "type": "array", "items": { "$ref": "#/$defs/condition" } } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["not"],
          "properties": { "not": { "$ref": "#/$defs/condition" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["path"],
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "operator": {
              "type": "string",
              "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "contains", "in", "exists", "not_exists", "truthy", "falsy", "regex"],
              "default": "eq"
            },
            "value": {}
          }
        }
      ]
    }
  }
}
